{
	"name": "npm-cooldown",
	"version": "0.0.0",
	"description": "Supply-chain protection for npm: installs dependencies as they were N days ago.",
	"keywords": [
		"npm",
		"security",
		"supply-chain",
		"install"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Zwyx/npm-cooldown.git"
	},
	"engines": {
		"node": ">=18"
	},
	"files": [
		"dist",
		"README.md"
	],
	"bin": {
		"npm-cooldown": "dist/index.js",
		"ncd": "dist/index.js"
	},
	"scripts": {
		"dev": "bun src/index.ts",
		"build": "npm run lint && tsc",
		"test": "vitest run",
		"prepack": "npm run build && npm run test",
		"lint": "eslint --max-warnings=0 .",
		"prettier": "prettier -w ."
	},
	"dependencies": {
		"semver": "^7.7.4"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.0.0",
		"@types/semver": "^7.7.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-only-warn": "^1.2.1",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.58.0",
		"vitest": "^2.0.0"
	}
}
